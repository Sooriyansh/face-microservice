<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Attendance Reports | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="admin">
  <% const safeRecords = typeof records !== 'undefined' ? records : []; %>
  <div class="enterprise-layout">
    <aside class="side-nav">
      <a href="/" class="brand-block"><span class="brand-mark"><i class="fa-solid fa-shield-halved"></i></span><span><strong>FaceAI</strong><small>Admin Reports</small></span></a>
      <nav class="side-menu">
        <a href="/"><i class="fa-solid fa-grid-2"></i>Dashboard</a>
        <a class="active" href="/attendance"><i class="fa-solid fa-calendar-check"></i>Attendance</a>
        <a href="/#employees"><i class="fa-solid fa-users-gear"></i>Employees</a>
        <a href="/#analytics"><i class="fa-solid fa-chart-line"></i>Analytics</a>
        <a href="/system-events"><i class="fa-solid fa-timeline"></i>System Events</a>
        <a href="/employee"><i class="fa-solid fa-user-lock"></i>Employee Portal</a>
      </nav>
      <div class="rbac-card"><span class="security-badge">No camera here</span><p>Face Detection Preview and Mark Attendance are available only in the employee workspace.</p></div>
      <form action="/logout" method="POST" class="logout-form"><button type="submit">Logout</button></form>
    </aside>

    <main class="workspace">
      <header class="topbar">
        <button class="mobile-menu-toggle" type="button" aria-label="Open navigation"><i class="fa-solid fa-bars"></i></button>
        <label class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input type="search" placeholder="Search attendance records"></label>
        <div class="topbar-actions">
          <span class="sync-pill"><span class="live-dot"></span>Live sync</span>
          <span class="clock" id="real-time-clock">--:--</span>
          <button class="icon-button theme-toggle" type="button" aria-label="Toggle theme"><i class="fa-solid fa-moon"></i></button>
          <span class="security-badge"><%= currentUser ? currentUser.role : 'admin' %></span>
          <button id="refresh-attendance" class="btn btn-primary"><i class="fa-solid fa-rotate-right"></i> Refresh</button>
        </div>
      </header>

      <section class="page-hero reveal">
        <div>
          <span class="status-chip"><span class="live-dot"></span> Admin attendance intelligence</span>
          <h1>Attendance</h1>
          <p>View all employee attendance records, confidence scores, location captures, and daily face recognition outcomes.</p>
        </div>
        <a class="btn btn-secondary" href="/employee"><i class="fa-solid fa-camera"></i> Employee Mark Attendance</a>
      </section>

      <section class="metric-grid compact reveal">
        <div class="metric-card"><span class="metric-icon success"><i class="fa-solid fa-user-check"></i></span><p>Present Records</p><strong><%= safeRecords.length %></strong></div>
        <div class="metric-card"><span class="metric-icon violet"><i class="fa-solid fa-fingerprint"></i></span><p>Avg Confidence</p><strong>99.1%</strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-location-dot"></i></span><p>Geo Captures</p><strong><%= safeRecords.filter((record) => record.location && record.location.latitude != null).length %></strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-cloud-arrow-up"></i></span><p>Sync State</p><strong>Live</strong></div>
      </section>

      <section class="panel reveal">
        <div class="panel-header split">
          <div><p class="eyebrow">Reports</p><h2>All Attendance Records</h2><p id="attendance-page-status" class="helper-text">Latest records shown below.</p></div>
          <div class="filter-controls"><input type="date" aria-label="Date filter"><button class="btn btn-secondary" type="button"><i class="fa-solid fa-file-export"></i> Export Logs</button></div>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Employee</th><th>Face Label</th><th>Marked At</th><th>Confidence</th><th>Location</th><th>Status</th></tr></thead>
            <tbody id="attendance-page-body">
              <% if (safeRecords.length === 0) { %><tr><td colspan="6">No attendance records found.</td></tr><% } %>
              <% safeRecords.forEach((record) => { %>
                <tr>
                  <td><%= record.student ? record.student.name : record.faceLabel %></td>
                  <td><code><%= record.faceLabel %></code></td>
                  <td><%= new Date(record.markedAt).toLocaleString() %></td>
                  <td><%= Number(record.confidence || 0).toFixed(3) %></td>
                  <td>
                    <% if (record.location && record.location.latitude != null && record.location.longitude != null) { %>
                      <a href="https://www.google.com/maps?q=<%= record.location.latitude %>,<%= record.location.longitude %>" target="_blank" rel="noopener noreferrer"><%= Number(record.location.latitude).toFixed(5) %>, <%= Number(record.location.longitude).toFixed(5) %></a>
                    <% } else { %>-<% } %>
                  </td>
                  <td><span class="security-badge">Present</span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
  <div class="toast-stack" id="toast-stack"></div>
  <script src="/script.js"></script>
</body>
</html>
