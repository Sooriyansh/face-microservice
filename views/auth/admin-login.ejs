<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="auth-page">
  <div class="auth-particles" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
  <header class="auth-top-nav">
    <a href="/login" class="brand-block auth-brand">
      <span class="brand-mark"><i class="fa-solid fa-shield-halved"></i></span>
      <span><strong>FaceAI Attend</strong><small>Admin Security Console</small></span>
    </a>
    <a href="/login" class="admin-login-glow secondary"><i class="fa-solid fa-users"></i> Employee Login</a>
  </header>

  <main class="auth-shell single-auth-shell">
    <section class="auth-panel admin-auth-panel reveal">
      <div>
        <span class="status-chip"><span class="live-dot"></span> Dedicated admin authentication</span>
        <h1>Admin Login</h1>
        <p>Admins authenticate with email and password only. No biometric registration is required for admin accounts.</p>
      </div>
      <% if (error) { %><p class="form-status status-error"><%= error %></p><% } %>
      <form class="stack-form auth-form" action="/admin-login" method="POST">
        <input type="hidden" name="next" value="<%= nextUrl %>">
        <label><span>Email Address</span><input type="email" name="email" placeholder="admin@company.com" required></label>
        <label><span>Password</span><input id="admin-login-password" type="password" name="password" placeholder="Enter password" required></label>
        <div class="auth-options-row">
          <label class="check-control"><input type="checkbox" class="show-password-toggle" data-target="admin-login-password"> <span>Show Password</span></label>
          <a href="/forgot-password">Forgot Password</a>
        </div>
        <button class="btn btn-primary wide" type="submit"><i class="fa-solid fa-user-shield"></i> Admin Sign In</button>
      </form>
      <p class="auth-switch">Need an admin account? <a href="/admin-signup">Create Admin Account</a></p>
    </section>
  </main>
  <div class="toast-stack" id="toast-stack"></div>
  <script src="/js/shared/script.js"></script>
</body>
</html>

