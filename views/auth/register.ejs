<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Employee Account | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
  <main class="auth-shell">
    <section class="auth-panel signup-panel-wide reveal">
      <a href="/login" class="brand-block auth-brand">
        <span class="brand-mark"><i class="fa-solid fa-fingerprint"></i></span>
        <span><strong>FaceAI Attend</strong><small>Create Employee Account</small></span>
      </a>
      <div>
        <span class="status-chip"><span class="live-dot"></span> Employee onboarding</span>
        <h1>Create Employee Account</h1>
        <p>Create your account now. Face sign-in is optional and can be set up later.</p>
      </div>
      <% if (error) { %><p class="form-status status-error"><%= error %></p><% } %>

      <form class="stack-form auth-form" id="signup-form" action="/signup" method="POST">
        <input type="hidden" name="role" id="signup-role" value="employee">

        <div class="form-grid">
          <label><span>Full Name</span><input type="text" name="name" placeholder="Rahul Sharma" required></label>
          <label><span>Email Address</span><input type="email" name="email" placeholder="you@company.com" required></label>
          <label class="employee-only"><span>Employee ID</span><input type="text" name="employeeId" placeholder="EMP-1042"></label>
          <label class="employee-only"><span>Department</span><input type="text" name="department" placeholder="Engineering"></label>
          <label class="employee-only"><span>Phone Number</span><input type="tel" name="phoneNumber" placeholder="+91 98765 43210"></label>
          <label><span>Password</span><input type="password" name="password" minlength="6" placeholder="Minimum 6 characters" required></label>
          <label><span>Confirm Password</span><input type="password" name="confirmPassword" minlength="6" placeholder="Confirm password" required></label>
        </div>

        <section class="employee-biometric-section employee-only" id="signup-biometric-section">
          <div class="panel-header split">
            <div>
              <p class="eyebrow">Optional Employee Face Registration</p>
              <h2>Face Registration</h2>
              <p class="helper-text">Skip this section to create the account with password login only.</p>
            </div>
            <span class="panel-badge" id="signup-biometric-progress">0% complete</span>
          </div>

          <div class="camera-shell enrollment-shell biometric-scanner-shell">
            <div class="camera-frame scanner-frame biometric-camera">
              <video id="enrollment-camera-feed" autoplay playsinline muted></video>
              <canvas id="enrollment-camera-canvas" hidden></canvas>
              <span class="camera-reticle"></span>
              <span class="scan-line camera-scan"></span>
              <div class="face-guide"><span></span><span></span><span></span><span></span></div>
            </div>
            <div class="scan-step-list">
              <span class="active">Front face scan</span>
              <span>Left angle scan</span>
              <span>Right angle scan</span>
              <span>Slight upward scan</span>
              <span>Slight downward scan</span>
              <span>Face check</span>
              <span>Secure face upload</span>
            </div>
            <div class="quality-grid">
              <div><strong id="face-quality">Quality 0%</strong><span>Photo quality</span></div>
              <div><strong id="lighting-quality">Lighting pending</strong><span>Lighting check</span></div>
              <div><strong id="face-validation">Face check pending</strong><span>Live face check</span></div>
              <div><strong id="alignment-status">Align face</strong><span>Head movement guidance</span></div>
            </div>
            <div class="camera-controls">
              <button type="button" id="start-enrollment-camera" class="btn btn-secondary"><i class="fa-solid fa-video"></i> Start Camera</button>
              <button type="button" id="capture-enrollment" class="btn btn-primary"><i class="fa-solid fa-crosshairs"></i> Capture Face Photos</button>
              <button type="button" id="stop-enrollment-camera" class="btn btn-secondary"><i class="fa-solid fa-video-slash"></i> Stop</button>
            </div>
            <p id="enrollment-camera-status" class="helper-text">Camera is off. Start camera only if you want to enable face login now.</p>
            <p id="enrollment-sample-status" class="form-status">Optional: capture 6 or more face photos to enable face sign-in now.</p>
          </div>
          <div id="enrollment-preview" class="sample-grid"></div>
        </section>

        <button class="btn btn-primary wide" type="submit"><i class="fa-solid fa-user-plus"></i> Create Employee Account</button>
        <p id="signup-form-status" class="form-status"></p>
      </form>
      <p class="auth-switch">Already have an employee account? <a href="/login">Sign In</a> · Admin? <a href="/admin-signup">Create Admin Account</a></p>
    </section>
  </main>
  <div class="toast-stack" id="toast-stack"></div>
  <script src="/js/shared/script.js"></script>
</body>
</html>

