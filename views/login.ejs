<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
  <main class="auth-shell dual-auth-shell">
    <section class="auth-panel reveal">
      <a href="/login" class="brand-block auth-brand">
        <span class="brand-mark"><i class="fa-solid fa-shield-halved"></i></span>
        <span><strong>FaceAI</strong><small>Admin Authentication</small></span>
      </a>
      <div>
        <span class="status-chip"><span class="live-dot"></span> JWT secure admin access</span>
        <h1>Admin Login</h1>
        <p>Admins sign in with email and password only. Face enrollment is not required for admin accounts.</p>
      </div>
      <% if (error) { %><p class="form-status status-error"><%= error %></p><% } %>
      <form class="stack-form auth-form" action="/login" method="POST">
        <input type="hidden" name="next" value="<%= nextUrl %>">
        <label><span>Email</span><input type="email" name="email" placeholder="admin@company.com" required></label>
        <label><span>Password</span><input type="password" name="password" placeholder="Enter password" required></label>
        <button class="btn btn-primary wide" type="submit"><i class="fa-solid fa-right-to-bracket"></i> Login as Admin</button>
      </form>
      <p class="auth-switch">New account? <a href="/signup">Signup</a> · <a href="/forgot-password">Forgot password?</a></p>
    </section>

    <section class="auth-panel employee-face-login reveal">
      <a href="/login" class="brand-block auth-brand">
        <span class="brand-mark"><i class="fa-solid fa-fingerprint"></i></span>
        <span><strong>FaceAI</strong><small>Employee Face Login</small></span>
      </a>
      <div>
        <span class="status-chip"><span class="live-dot"></span> Face recognition only</span>
        <h1>Employee Login</h1>
        <p>Employees sign in with face recognition only. The webcam opens, AI verifies the face, and a successful match opens the dashboard.</p>
      </div>
      <div class="camera-shell face-login-shell">
        <div class="camera-frame scanner-frame biometric-camera">
          <video id="employee-login-camera-feed" autoplay playsinline muted></video>
          <canvas id="employee-login-camera-canvas" hidden></canvas>
          <span class="camera-reticle"></span>
          <span class="scan-line camera-scan"></span>
          <span class="face-box" id="employee-login-face-box" hidden></span>
          <div class="scanner-state" id="employee-login-scanner-state">Initializing Camera</div>
          <div class="face-guide"><span></span><span></span><span></span><span></span></div>
        </div>
        <div class="quality-grid">
          <div><strong id="employee-login-confidence">Confidence 0%</strong><span>Secure match score</span></div>
          <div><strong id="employee-login-state">Ready</strong><span>Biometric state</span></div>
        </div>
        <div class="camera-controls">
          <button type="button" id="start-employee-face-login" class="btn btn-primary"><i class="fa-solid fa-video"></i> Open Webcam</button>
          <button type="button" id="retry-employee-face-login" class="btn btn-secondary"><i class="fa-solid fa-rotate-right"></i> Retry Scan</button>
        </div>
        <p id="employee-face-login-status" class="form-status">Open webcam to start secure employee face authentication.</p>
      </div>
    </section>
  </main>
  <div class="toast-stack" id="toast-stack"></div>
  <script src="/script.js"></script>
</body>
</html>


