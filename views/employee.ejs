<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Employee Workspace | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="employee">
  <% const safeEmployee = typeof employee !== 'undefined' && employee ? employee : null; %>
  <% const safeRecords = typeof records !== 'undefined' ? records : []; %>
  <% const safeEvents = typeof personalEvents !== 'undefined' ? personalEvents : []; %>
  <% const safeWorkSession = typeof workSession !== 'undefined' ? workSession : null; %>
  <% const safeUser = typeof currentUser !== 'undefined' ? currentUser : null; %>
  <div class="enterprise-layout employee-layout">
    <aside class="side-nav">
      <a href="/employee" class="brand-block"><span class="brand-mark"><i class="fa-solid fa-fingerprint"></i></span><span><strong>FaceAI</strong><small>Employee Portal</small></span></a>
      <nav class="side-menu">
        <a class="active" href="/employee"><i class="fa-solid fa-camera"></i>Mark Attendance</a>
        <a href="#identity-enrollment"><i class="fa-solid fa-id-card-clip"></i>Identity Enrollment</a>
        <a href="#daily-work-session"><i class="fa-solid fa-satellite-dish"></i>Daily Work Session</a>
        <a href="#personal-attendance"><i class="fa-solid fa-calendar-user"></i>My Attendance</a>
        <a href="#personal-events"><i class="fa-solid fa-clock-rotate-left"></i>My Activity Logs</a>
        <a href="#device"><i class="fa-solid fa-laptop"></i>Device Status</a>
      </nav>
      <div class="rbac-card">
        <span class="security-badge"><%= safeUser ? safeUser.role : 'Employee' %> role</span>
        <p>You can view only your own attendance, login history, and system events.</p>
        <% if (safeUser && safeUser.role === 'admin') { %><a class="mini-link" href="/">Admin dashboard</a><% } %>
        <form action="/logout" method="POST" class="logout-form"><button type="submit">Logout</button></form>
      </div>
    </aside>

    <main class="workspace">
      <header class="topbar">
        <button class="mobile-menu-toggle" type="button" aria-label="Open navigation"><i class="fa-solid fa-bars"></i></button>
        <label class="search-box"><i class="fa-solid fa-lock"></i><input type="search" value="<%= safeEmployee ? safeEmployee.name : 'Employee demo profile' %>" readonly></label>
        <div class="topbar-actions">
          <span class="sync-pill"><span class="live-dot"></span>Personal live sync</span>
          <span class="clock" id="real-time-clock">--:--</span>
          <button class="icon-button theme-toggle" type="button" aria-label="Toggle theme"><i class="fa-solid fa-moon"></i></button>
          <span class="avatar"><%= safeEmployee ? safeEmployee.name.slice(0,2).toUpperCase() : (safeUser ? safeUser.name.slice(0,2).toUpperCase() : 'EM') %></span>
        </div>
      </header>

      <section class="page-hero reveal">
        <div>
          <span class="status-chip"><span class="live-dot"></span> Secure personal attendance</span>
          <h1>Employee Dashboard</h1>
          <p>Mark attendance with face recognition and review only your own attendance, login history, system events, working hours, and device activity.</p>
        </div>
      </section>

      <section class="panel enrollment-panel reveal" id="identity-enrollment">
        <div class="panel-header split">
          <div>
            <p class="eyebrow">Employee biometric enrollment</p>
            <h2>Identity Enrollment</h2>
            <p class="helper-text">Register or update your own face data with multi-angle scans, alignment guidance, quality checks, and secure biometric upload.</p>
          </div>
          <span class="status-badge enrollment-<%= String(safeEmployee && safeEmployee.enrollmentStatus ? safeEmployee.enrollmentStatus : 'Pending').toLowerCase().replaceAll(' ', '-') %>"><%= safeEmployee && safeEmployee.enrollmentStatus ? safeEmployee.enrollmentStatus : 'Pending' %></span>
        </div>
        <form id="student-form" class="stack-form biometric-enrollment-form" data-student-id="<%= safeEmployee ? safeEmployee._id : '' %>">
          <div class="form-grid">
            <label><span>Name</span><input type="text" name="name" value="<%= safeEmployee ? safeEmployee.name : (safeUser ? safeUser.name : '') %>" placeholder="Rahul Sharma" required></label>
            <label><span>Face Label</span><input type="text" name="faceLabel" value="<%= safeEmployee ? safeEmployee.faceLabel : (safeUser ? safeUser.email.split('@')[0].replace(/[^a-zA-Z0-9_]/g, '_') : '') %>" placeholder="rahul_sharma" <%= safeEmployee ? 'readonly' : '' %> required></label>
            <label><span>Joining Date</span><input type="date" name="joiningDate" value="<%= safeEmployee && safeEmployee.joiningDate ? new Date(safeEmployee.joiningDate).toISOString().slice(0,10) : '' %>" required></label>
            <label><span>Employee ID</span><input type="text" name="rollNumber" value="<%= safeEmployee ? safeEmployee.rollNumber : '' %>" placeholder="EMP-1042"></label>
            <label><span>Department</span><input type="text" name="department" value="<%= safeEmployee ? safeEmployee.department : '' %>" placeholder="Engineering"></label>
            <label><span>Email</span><input type="email" name="email" value="<%= safeEmployee ? safeEmployee.email : (safeUser ? safeUser.email : '') %>" placeholder="rahul@company.com"></label>
          </div>
          <div class="camera-shell enrollment-shell biometric-scanner-shell">
            <div class="camera-frame scanner-frame biometric-camera">
              <video id="enrollment-camera-feed" autoplay playsinline muted></video>
              <canvas id="enrollment-camera-canvas" hidden></canvas>
              <span class="camera-reticle"></span>
              <span class="scan-line camera-scan"></span>
              <div class="face-guide"><span></span><span></span><span></span><span></span></div>
            </div>
            <div class="quality-grid">
              <div><strong id="face-quality">Quality 0%</strong><span>Capture quality indicator</span></div>
              <div><strong id="lighting-quality">Lighting pending</strong><span>Lighting detection</span></div>
              <div><strong id="face-validation">Face validation pending</strong><span>AI face detection</span></div>
              <div><strong id="alignment-status">Align face</strong><span>Face alignment guide</span></div>
            </div>
            <div class="camera-controls">
              <button type="button" id="start-enrollment-camera" class="btn btn-secondary"><i class="fa-solid fa-video"></i> Start Camera</button>
              <button type="button" id="capture-enrollment" class="btn btn-primary"><i class="fa-solid fa-crosshairs"></i> Multi-Angle Scan</button>
              <button type="button" id="stop-enrollment-camera" class="btn btn-secondary"><i class="fa-solid fa-video-slash"></i> Stop</button>
            </div>
            <p id="enrollment-camera-status" class="helper-text">Camera is off. Capture at least 6 face samples.</p>
            <p id="enrollment-sample-status" class="form-status">Minimum: 6 samples | Recommended: 12 samples</p>
          </div>
          <div id="enrollment-preview" class="sample-grid"></div>
          <button type="submit" class="btn btn-primary wide"><i class="fa-solid fa-cloud-arrow-up"></i> <%= safeEmployee ? 'Update Face Data' : 'Register Face' %></button>
          <p id="student-form-status" class="form-status"></p>
        </form>
      </section>

      <section class="panel work-session-console reveal" id="daily-work-session" data-employee-id="<%= safeEmployee ? safeEmployee._id : '' %>">
        <div class="panel-header split">
          <div>
            <p class="eyebrow">Smart work session</p>
            <h2>Daily Work Session</h2>
            <p class="helper-text">Tracking starts only after face attendance or the 08:00 AM work window after login, and stops immediately after checkout.</p>
          </div>
          <span class="panel-badge" id="session-sync-badge"><span class="live-dot"></span> Secure session monitoring</span>
        </div>
        <div class="session-grid">
          <div class="session-status-card">
            <span class="session-state <%= safeWorkSession ? safeWorkSession.status : 'offline' %>" id="session-state-dot"></span>
            <p>Live Working Status</p>
            <strong id="session-status-text"><%= safeWorkSession ? safeWorkSession.status.replace('_', ' ').toUpperCase() : 'PENDING ATTENDANCE' %></strong>
            <small id="session-status-detail"><%= safeWorkSession ? 'Monitoring active for today.' : 'Mark attendance to begin tracking.' %></small>
          </div>
          <div class="session-status-card">
            <i class="fa-solid fa-stopwatch"></i>
            <p>Session Timer</p>
            <strong id="session-timer" data-started-at="<%= safeWorkSession && safeWorkSession.startedAt ? new Date(safeWorkSession.startedAt).toISOString() : '' %>" data-checkout-at="<%= safeWorkSession && safeWorkSession.checkoutAt ? new Date(safeWorkSession.checkoutAt).toISOString() : '' %>">00:00:00</strong>
            <small>Total working hours tracked live</small>
          </div>
          <div class="session-status-card">
            <i class="fa-solid fa-wave-square"></i>
            <p>Activity Collector</p>
            <strong id="session-event-count"><%= safeWorkSession && safeWorkSession.events ? safeWorkSession.events.length : 0 %></strong>
            <small>Live device and productivity events</small>
          </div>
          <div class="session-status-card">
            <i class="fa-solid fa-gauge-high"></i>
            <p>Productivity Score</p>
            <strong id="session-productivity"><%= safeWorkSession ? safeWorkSession.productivityScore : 0 %>%</strong>
            <small>Updates from active, idle, app, and website activity</small>
          </div>
        </div>

        <div class="session-monitor-layout">
          <div>
            <div class="mini-section-header">
              <h3>Activity Monitor Panel</h3>
              <span class="sync-pill"><span class="live-dot"></span>Live events</span>
            </div>
            <div class="timeline-stream animated-timeline" id="employee-session-events">
              <% if (!safeWorkSession || !safeWorkSession.events || safeWorkSession.events.length === 0) { %>
                <div><span class="event-dot"></span><strong>Waiting for attendance</strong><p>Events like Laptop Started, Screen Unlocked, Chrome Opened, and Attendance Marked will appear here.</p></div>
              <% } %>
              <% if (safeWorkSession && safeWorkSession.events) { safeWorkSession.events.slice(-10).reverse().forEach((event) => { %>
                <div>
                  <span class="event-dot"></span>
                  <strong><%= event.type %></strong>
                  <p><%= new Date(event.occurredAt).toLocaleString() %> Â· <%= event.message || event.deviceInfo || 'Live activity event' %></p>
                </div>
              <% }) } %>
            </div>
          </div>
          <div class="monitor-health-panel">
            <div><span class="live-dot"></span><strong>WebSocket connection</strong><p id="ws-health">Connected</p></div>
            <div><span class="live-dot"></span><strong>MongoDB live stream</strong><p>Change stream ready</p></div>
            <div><span class="live-dot"></span><strong>Event collector</strong><p id="collector-health">Browser + Windows collectors armed</p></div>
            <div><span class="live-dot"></span><strong>Privacy boundary</strong><p>No passwords, files, messages, or browser credentials are tracked.</p></div>
            <div><span class="live-dot"></span><strong>Tracking rule</strong><p>Disabled after checkout until next working day</p></div>
            <button type="button" class="btn btn-primary wide" id="complete-daily-task" <%= !safeWorkSession || safeWorkSession.status === 'checked_out' ? 'disabled' : '' %> data-session-id="<%= safeWorkSession ? safeWorkSession._id : '' %>"><i class="fa-solid fa-circle-check"></i> Complete Daily Task</button>
            <p class="form-status" id="checkout-result"><%= safeWorkSession && safeWorkSession.status === 'checked_out' ? "Today's work session completed successfully." : '' %></p>
          </div>
        </div>
      </section>

      <section class="employee-grid reveal">
        <div class="panel scanner-console">
          <div class="panel-header">
            <div><p class="eyebrow">Face Recognition Preview Camera</p><h2>Mark Attendance</h2></div>
            <span class="panel-badge"><span class="live-dot"></span> Employee only</span>
          </div>
          <div class="camera-shell">
            <div class="camera-frame scanner-frame large">
              <video id="camera-feed" autoplay playsinline muted></video>
              <canvas id="camera-canvas" hidden></canvas>
              <span class="camera-reticle"></span>
              <span class="scan-line camera-scan"></span>
                          <span class="face-box" id="attendance-face-box" hidden></span>
              <div class="scanner-state" id="attendance-scanner-state">Initializing Camera</div>
            </div>
            <div class="quality-grid">
              <div><strong id="attendance-confidence">Confidence 0%</strong><span>Live match score</span></div>
              <div><strong id="attendance-face-state">Ready</strong><span>Face tracking</span></div>
              <div><strong id="attendance-light-state">Lighting pending</strong><span>Brightness check</span></div>
              <div><strong id="attendance-quality-state">Quality pending</strong><span>Sharpness check</span></div>
            </div>
            <div class="camera-controls">
              <button type="button" id="start-camera" class="btn btn-primary"><i class="fa-solid fa-video"></i> Start Camera</button>
              <button type="button" id="scan-now" class="btn btn-secondary"><i class="fa-solid fa-fingerprint"></i> Mark Attendance</button>
              <button type="button" id="stop-camera" class="btn btn-secondary"><i class="fa-solid fa-video-slash"></i> Stop</button>
            </div>
            <p id="camera-status" class="helper-text">Camera is off.</p>
            <p id="location-status" class="helper-text">Location capture starts with camera permission.</p>
            <p id="camera-loader" class="loading-skeleton"></p>
            <p id="recognition-result" class="form-status">Scanner is ready. Keep your face centered inside the frame.</p>
          </div>
        </div>

        <aside class="panel" id="device">
          <div class="panel-header"><div><p class="eyebrow">Personal status</p><h2>Device Status</h2></div></div>
          <div class="status-stack">
            <div><span class="live-dot"></span><strong>Laptop Online</strong><p>Windows tracker connected</p></div>
            <div><span class="live-dot"></span><strong>Attendance Status</strong><p><%= safeRecords.length ? 'Marked today' : 'Pending face recognition' %></p></div>
            <div><span class="live-dot"></span><strong>Working Hours</strong><p>7h 42m tracked today</p></div>
            <div><span class="live-dot danger-dot"></span><strong>RBAC Boundary</strong><p>Other employee data is hidden</p></div>
          </div>
        </aside>
      </section>

      <section class="metric-grid compact reveal">
        <div class="metric-card"><span class="metric-icon success"><i class="fa-solid fa-calendar-check"></i></span><p>My Attendance</p><strong><%= safeRecords.length %></strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-right-to-bracket"></i></span><p>Login History</p><strong><%= safeEvents.filter((event) => ['Login', 'Logout'].includes(event.event)).length || 4 %></strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-lock-open"></i></span><p>Lock/Unlock</p><strong><%= safeEvents.filter((event) => ['Lock', 'Unlock'].includes(event.event)).length || 8 %></strong></div>
        <div class="metric-card"><span class="metric-icon violet"><i class="fa-solid fa-bed"></i></span><p>Sleep/Wakeup</p><strong><%= safeEvents.filter((event) => ['Sleep', 'Wakeup'].includes(event.event)).length || 2 %></strong></div>
      </section>

      <section class="admin-grid reveal" id="personal-events">
        <div class="panel">
          <div class="panel-header"><div><p class="eyebrow">Personal Activity Timeline</p><h2>My System Events</h2></div></div>
          <div class="timeline-stream">
            <% if (safeEvents.length === 0) { %>
              <div><span class="event-dot"></span><strong>No personal events captured yet</strong><p>Startup, shutdown, login/logout, lock/unlock, sleep/wakeup events will appear here.</p></div>
            <% } %>
            <% safeEvents.slice(0, 10).forEach((event) => { %>
              <div><span class="event-dot"></span><strong><%= event.event %></strong><p><%= new Date(event.occurredAt).toLocaleString() %> Â· <%= event.meaning || event.sourceLog || 'System event' %></p></div>
            <% }) %>
          </div>
        </div>
        <div class="panel" id="personal-attendance">
          <div class="panel-header"><div><p class="eyebrow">Private records</p><h2>My Attendance History</h2></div></div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Date</th><th>Time</th><th>Confidence</th><th>Status</th></tr></thead>
              <tbody id="attendance-page-body">
                <% if (safeRecords.length === 0) { %><tr><td colspan="4">No personal attendance records found.</td></tr><% } %>
                <% safeRecords.forEach((record) => { %>
                  <tr><td><%= record.dateKey %></td><td><%= new Date(record.markedAt).toLocaleTimeString() %></td><td><%= Number(record.confidence || 0).toFixed(3) %></td><td><span class="security-badge">Present</span></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </div>
  <div class="toast-stack" id="toast-stack"></div>
  <div class="modal-backdrop" id="checkout-modal" hidden>
    <form class="checkout-modal panel" id="checkout-form">
      <div class="panel-header">
        <div><p class="eyebrow">Check-out confirmation</p><h2>Complete Daily Task</h2></div>
        <button class="icon-button" type="button" id="close-checkout-modal" aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <label class="stack-form">
        <span>What work did you complete today?</span>
        <textarea id="checkout-note" name="note" rows="6" placeholder="Summarize completed tasks, blockers, handoffs, or final notes..." required></textarea>
      </label>
      <button type="submit" class="btn btn-primary wide"><i class="fa-solid fa-flag-checkered"></i> Finish Work Session</button>
      <p class="form-status" id="checkout-form-status"></p>
    </form>
  </div>
  <div class="modal-backdrop" id="monitoring-permission-modal" hidden>
    <div class="checkout-modal panel">
      <div class="panel-header">
        <div><p class="eyebrow">Monitoring permission</p><h2>Work Session Consent</h2></div>
      </div>
      <p class="helper-text">This organization wants permission to monitor your device activity during work sessions for productivity and attendance purposes.</p>
      <div class="permission-list">
        <span><i class="fa-solid fa-check"></i> System event monitoring</span>
        <span><i class="fa-solid fa-check"></i> Sleep/wakeup tracking</span>
        <span><i class="fa-solid fa-check"></i> Device activity monitoring</span>
        <span><i class="fa-solid fa-check"></i> Lock/unlock detection</span>
      </div>
      <p class="form-status">Attendance still works if you deny monitoring. Admin will see â€œMonitoring Permission Deniedâ€.</p>
      <div class="hero-actions">
        <button type="button" class="btn btn-primary" id="allow-monitoring"><i class="fa-solid fa-shield-check"></i> Allow Monitoring</button>
        <button type="button" class="btn btn-secondary" id="deny-monitoring"><i class="fa-solid fa-ban"></i> Deny</button>
      </div>
    </div>
  </div>
  <script src="/script.js"></script>
</body>
</html>



