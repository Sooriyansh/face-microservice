<div class="notification-drawer" id="notification-drawer" hidden>
  <div class="notification-panel" role="dialog" aria-label="Notification center">
    <div class="notification-header">
      <div>
        <p class="eyebrow">Notification center</p>
        <h2>Alerts</h2>
      </div>
      <div class="notification-actions">
        <button type="button" class="icon-button" id="enable-notifications" aria-label="Enable browser notifications"><i class="fa-solid fa-broadcast-tower"></i></button>
        <button type="button" class="icon-button" id="mark-all-notifications" aria-label="Mark all as read"><i class="fa-solid fa-check-double"></i></button>
        <button type="button" class="icon-button" id="close-notification-drawer" aria-label="Close notifications"><i class="fa-solid fa-xmark"></i></button>
      </div>
    </div>
    <div class="notification-tabs" id="notification-tabs">
      <button type="button" class="active" data-tab="all">All</button>
      <button type="button" data-tab="unread">Unread</button>
      <button type="button" data-tab="attendance">Attendance</button>
      <button type="button" data-tab="leave">Leave</button>
      <button type="button" data-tab="reports">Reports</button>
      <button type="button" data-tab="system">System</button>
    </div>
    <div class="notification-list" id="notification-list">
      <div class="notification-empty">Loading notifications...</div>
    </div>
  </div>
</div>
