<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="admin">
  <% const safeStudents = typeof students !== 'undefined' ? students : []; %>
  <% const safeRecentAttendance = typeof recentAttendance !== 'undefined' ? recentAttendance : []; %>
  <% const presentToday = typeof todayAttendanceCount !== 'undefined' ? todayAttendanceCount : safeRecentAttendance.length; %>
  <% const totalEmployees = typeof studentCount !== 'undefined' ? studentCount : safeStudents.length; %>
  <% const safeLiveSessions = typeof liveSessions !== 'undefined' ? liveSessions : []; %>
  <% const sessionFor = (employeeId) => safeLiveSessions.find((session) => String(session.employee && session.employee._id ? session.employee._id : session.employee) === String(employeeId)); %>
  <% const activeEmployees = Math.max(Math.min(totalEmployees, Math.round(totalEmployees * 0.72)), presentToday); %>
  <% const absentToday = Math.max(totalEmployees - presentToday, 0); %>

  <div class="enterprise-layout">
    <aside class="side-nav">
      <a href="/" class="brand-block">
        <span class="brand-mark"><i class="fa-solid fa-shield-halved"></i></span>
        <span><strong>FaceAI</strong><small>RBAC Console</small></span>
      </a>
      <nav class="side-menu">
        <a class="active" href="/"><i class="fa-solid fa-grid-2"></i>Dashboard</a>
        <a href="/attendance"><i class="fa-solid fa-calendar-check"></i>Attendance</a>
        <a href="#employees"><i class="fa-solid fa-users-gear"></i>Employees</a>
        <a href="#analytics"><i class="fa-solid fa-chart-line"></i>Analytics</a>
        <a href="/system-events"><i class="fa-solid fa-timeline"></i>System Events</a>
        <a href="#live-monitoring"><i class="fa-solid fa-satellite-dish"></i>Monitoring</a>
        <a href="#reports"><i class="fa-solid fa-file-shield"></i>Reports</a>
        <a href="#settings"><i class="fa-solid fa-sliders"></i>Settings</a>
      </nav>
      <div class="rbac-card">
        <span class="security-badge">Admin role</span>
        <p>Full monitoring access. Employee camera attendance lives in the employee workspace.</p>
        <a href="/employee" class="mini-link">Open employee view</a>
        <form action="/logout" method="POST" class="logout-form"><button type="submit">Logout</button></form>
      </div>
    </aside>

    <main class="workspace">
      <header class="topbar">
        <button class="mobile-menu-toggle" type="button" aria-label="Open navigation"><i class="fa-solid fa-bars"></i></button>
        <label class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input type="search" placeholder="Search employees, events, reports"></label>
        <div class="topbar-actions">
          <span class="sync-pill"><span class="live-dot"></span>Live sync</span>
          <span class="clock" id="real-time-clock">--:--</span>
          <button class="icon-button theme-toggle" type="button" aria-label="Toggle theme"><i class="fa-solid fa-moon"></i></button>
          <button class="icon-button" type="button" aria-label="Notifications"><i class="fa-solid fa-bell"></i></button>
          <div class="profile-menu">
            <button class="profile-trigger" type="button"><span class="avatar"><%= currentUser ? currentUser.name.slice(0,2).toUpperCase() : 'AD' %></span><span class="profile-meta"><%= currentUser ? currentUser.name : 'Admin' %></span><i class="fa-solid fa-chevron-down"></i></button>
            <div class="profile-dropdown">
              <a href="/system-events">Security timeline</a>
              <a href="/employee">Employee workspace</a>
              <a href="#settings">Access policy</a>
              <form action="/logout" method="POST"><button type="submit">Logout</button></form>
            </div>
          </div>
        </div>
      </header>

      <section class="hero-panel reveal">
        <div>
          <span class="status-chip"><span class="live-dot"></span> Enterprise security dashboard</span>
          <h1>Attendance Management + Real-Time Employee Activity Tracking</h1>
          <p>Monitor attendance, laptop activity, login/logout events, lock/unlock history, live sync health, and employee analytics from one RBAC-protected admin console.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/system-events"><i class="fa-solid fa-satellite-dish"></i> Monitor Events</a>
            <a class="btn btn-secondary" href="/employee"><i class="fa-solid fa-user-lock"></i> Employee Portal</a>
          </div>
        </div>
        <div class="security-map" aria-label="Live monitoring visualization">
          <div class="radar-ring"></div>
          <div class="radar-core"><i class="fa-solid fa-fingerprint"></i></div>
          <span style="--x:18%;--y:22%">ON</span>
          <span style="--x:72%;--y:28%">Login</span>
          <span style="--x:36%;--y:76%">Face</span>
          <span style="--x:78%;--y:70%" class="alert">Lock</span>
        </div>
      </section>

      <section class="metric-grid reveal">
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-users"></i></span><p>Total Employees</p><strong><%= totalEmployees %></strong></div>
        <div class="metric-card"><span class="metric-icon success"><i class="fa-solid fa-calendar-day"></i></span><p>Present Today</p><strong><%= presentToday %></strong></div>
        <div class="metric-card"><span class="metric-icon success"><i class="fa-solid fa-user-check"></i></span><p>Active Employees</p><strong id="dashboard-active-count"><%= activeEmployees %></strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-hourglass-half"></i></span><p>Idle Employees</p><strong id="dashboard-idle-count">0</strong></div>
        <div class="metric-card"><span class="metric-icon danger"><i class="fa-solid fa-user-xmark"></i></span><p>Offline Employees</p><strong id="dashboard-offline-count"><%= absentToday %></strong></div>
        <div class="metric-card"><span class="metric-icon violet"><i class="fa-solid fa-circle-check"></i></span><p>Checked-Out Employees</p><strong id="dashboard-checkout-count">0</strong></div>
        <div class="metric-card"><span class="metric-icon violet"><i class="fa-solid fa-fingerprint"></i></span><p>Security Accuracy %</p><strong>99.7%</strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-bolt"></i></span><p>Live Sessions</p><strong><%= safeLiveSessions.length %></strong></div>
      </section>

      <section class="panel reveal" id="live-monitoring">
        <div class="panel-header split">
          <div>
            <p class="eyebrow">Admin real-time monitoring</p>
            <h2>Employee Live Status</h2>
            <p class="helper-text">Green active, yellow idle, red offline, and blue checked out indicators update from the smart work session API.</p>
          </div>
          <div class="connection-rack">
            <span><span class="live-dot"></span>Live sync pulse</span>
            <span><span class="live-dot"></span>WebSocket connected</span>
            <span><span class="live-dot"></span>MongoDB stream</span>
            <span><span class="live-dot"></span>Event collector</span>
          </div>
        </div>
        <div class="status-summary-strip">
          <div><span class="status-light status-active"></span><strong id="admin-active-count">0</strong><small>Active employees</small></div>
          <div><span class="status-light status-idle"></span><strong id="admin-idle-count">0</strong><small>Idle employees</small></div>
          <div><span class="status-light status-checkout"></span><strong id="admin-checkout-count">0</strong><small>Checked-out employees</small></div>
          <div><span class="status-light status-offline"></span><strong id="admin-offline-count">0</strong><small>Offline employees</small></div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Employee Name</th>
                <th>Device State</th>
                <th>Laptop ON Since</th>
                <th>Active Time</th>
                <th>Idle Time</th>
                <th>Sleep Duration</th>
                <th>Last Activity</th>
                <th>Attendance Time</th>
                <th>Checkout Time</th>
                <th>Productivity Score</th>
              </tr>
            </thead>
            <tbody id="admin-monitoring-body">
              <% if (safeStudents.length === 0) { %><tr><td colspan="10">No employees registered yet.</td></tr><% } %>
              <% safeStudents.forEach((student) => { const session = sessionFor(student._id); const status = session ? session.status : 'offline'; %>
                <tr>
                  <td><span class="person-cell"><span class="avatar"><%= (student.name || 'E').slice(0,2).toUpperCase() %></span><strong><%= student.name %></strong></span></td>
                  <td><span class="status-badge status-<%= status %>"><%= session ? session.deviceState : 'Offline' %></span></td>
                  <td><%= session && session.startedAt ? new Date(session.startedAt).toLocaleTimeString() : '-' %></td>
                  <td>-</td>
                  <td>-</td>
                  <td>-</td>
                  <td><%= session && session.lastActivityAt ? new Date(session.lastActivityAt).toLocaleTimeString() : '-' %></td>
                  <td><%= session && session.attendanceTime ? new Date(session.attendanceTime).toLocaleTimeString() : '-' %></td>
                  <td><%= session && session.checkoutAt ? new Date(session.checkoutAt).toLocaleTimeString() : '-' %></td>
                  <td><%= session ? session.productivityScore : 0 %>%</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-grid reveal" id="employees">
        <div class="panel enrollment-panel">
          <div class="panel-header split">
            <div>
              <p class="eyebrow">Enrollment review</p>
              <h2>Employee Identity Status</h2>
              <p class="helper-text">Employees register and update their own face data. Admin can only review biometric verification status and reports.</p>
            </div>
            <span class="panel-badge">Admin monitor only</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Employee</th><th>Face Label</th><th>Samples</th><th>Enrollment Status</th><th>Reviewed</th></tr></thead>
              <tbody>
                <% if (safeStudents.length === 0) { %><tr><td colspan="5">No employee identity records found.</td></tr><% } %>
                <% safeStudents.forEach((student) => { %>
                  <tr>
                    <td><span class="person-cell"><span class="avatar"><%= (student.name || 'E').slice(0,2).toUpperCase() %></span><strong><%= student.name %></strong></span></td>
                    <td><code><%= student.faceLabel %></code></td>
                    <td><%= student.enrollmentImages ? student.enrollmentImages.length : 0 %></td>
                    <td><span class="status-badge enrollment-<%= String(student.enrollmentStatus || 'Pending').toLowerCase().replaceAll(' ', '-') %>"><%= student.enrollmentStatus || 'Pending' %></span></td>
                    <td><%= student.enrollmentReviewedAt ? new Date(student.enrollmentReviewedAt).toLocaleDateString() : 'Awaiting review' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <aside class="panel live-feed-panel">
          <div class="panel-header">
            <div><p class="eyebrow">WebSocket style</p><h2>Live Activity Feed</h2></div>
          </div>
          <div class="activity-feed realtime-feed">
            <div class="severity-success"><span class="live-dot"></span><strong>Rahul laptop started</strong><p>08:12 AM · Windows activity monitor</p></div>
            <div><span class="live-dot"></span><strong>Ankit entered sleep mode</strong><p>08:46 AM · Session continuity</p></div>
            <div class="severity-success"><span class="live-dot"></span><strong>Priya marked attendance successfully</strong><p>09:02 AM · Face recognition AI</p></div>
            <div><span class="live-dot"></span><strong>Rohit unlocked screen</strong><p>09:18 AM · Screen security</p></div>
            <div class="severity-danger"><span class="live-dot danger-dot"></span><strong>Aman logged out</strong><p>09:41 AM · Critical access event</p></div>
          </div>
        </aside>
      </section>

      <section class="analytics-grid reveal" id="analytics">
        <div class="panel">
          <div class="panel-header"><div><p class="eyebrow">Analytics</p><h2>Attendance Trend</h2></div></div>
          <div class="line-chart">
            <span style="--h:48%"></span><span style="--h:62%"></span><span style="--h:58%"></span><span style="--h:79%"></span><span style="--h:72%"></span><span style="--h:86%"></span><span style="--h:66%"></span>
          </div>
        </div>
        <div class="panel">
          <div class="panel-header"><div><p class="eyebrow">Activity heatmap</p><h2>Working Hour Density</h2></div></div>
          <div class="heatmap">
            <% for (let i = 0; i < 42; i += 1) { %><span style="--alpha:<%= ((i % 6) + 2) / 10 %>"></span><% } %>
          </div>
        </div>
        <div class="panel integrations-panel" id="reports">
          <div class="panel-header"><div><p class="eyebrow">Integration ready</p><h2>Tech Features</h2></div></div>
          <div class="integration-grid">
            <span><i class="fa-solid fa-plug-circle-bolt"></i> WebSocket live sync</span>
            <span><i class="fa-solid fa-database"></i> MongoDB change streams</span>
            <span><i class="fa-solid fa-brain"></i> Face recognition AI</span>
            <span><i class="fa-solid fa-desktop"></i> Electron desktop tracker</span>
            <span><i class="fa-solid fa-list-check"></i> System event collector</span>
            <span><i class="fa-brands fa-windows"></i> Windows activity monitor</span>
          </div>
        </div>
      </section>

      <section class="panel reveal" id="settings">
        <div class="panel-header">
          <div><p class="eyebrow">RBAC policy</p><h2>Registered Employees</h2></div>
          <span class="panel-badge">Admin can view all</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Employee</th><th>Face Label</th><th>Department</th><th>Joining</th><th>Access</th></tr></thead>
            <tbody id="students-table-body">
              <% if (safeStudents.length === 0) { %><tr><td colspan="5">No employees registered yet.</td></tr><% } %>
              <% safeStudents.forEach((student) => { %>
                <tr>
                  <td><span class="person-cell"><span class="avatar"><%= (student.name || 'E').slice(0,2).toUpperCase() %></span><strong><%= student.name %></strong></span></td>
                  <td><code><%= student.faceLabel %></code></td>
                  <td><%= student.department || '-' %></td>
                  <td><%= student.joiningDate ? new Date(student.joiningDate).toLocaleDateString() : '-' %></td>
                  <td><span class="security-badge">Employee</span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <div class="toast-stack" id="toast-stack"></div>
  <script src="/script.js"></script>
</body>
</html>
