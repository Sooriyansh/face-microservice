<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Face Recognition Attendance System</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <% const safeStudents = typeof students !== 'undefined' ? students : []; %>
    <% const safeRecentAttendance = typeof recentAttendance !== 'undefined' ? recentAttendance : []; %>
    <% const attendancePct = safeStudents.length ? Math.round((safeRecentAttendance.length / safeStudents.length) * 100) : 0; %>
    <% const attendanceCounts = safeRecentAttendance.reduce((acc, record) => {
        acc[record.faceLabel] = (acc[record.faceLabel] || 0) + 1;
        return acc;
    }, {}); %>
    <% const maxAttendanceCount = Math.max(...Object.values(attendanceCounts), 1); %>

    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="noise-layer"></div>

    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-logo">
                <span class="logo-icon"><i class="fa-solid fa-shield-halved"></i></span>
                <span class="logo-text">FaceAI<span>Attend</span></span>
            </a>
            <button class="mobile-menu-toggle" type="button" aria-label="Open navigation">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="navbar-menu">
                <a href="#dashboard" class="navbar-link active">Dashboard</a>
                <a href="/attendance" class="navbar-link">Attendance</a>
                <a href="#students" class="navbar-link">Students</a>
                <a href="#analytics" class="navbar-link">Analytics</a>
                <a href="/system-events" class="navbar-link">System Events</a>
            </div>
            <div class="navbar-actions">
                <button class="icon-button theme-toggle" type="button" aria-label="Toggle dark mode"><i class="fa-solid fa-moon"></i></button>
                <div class="profile-menu">
                    <button class="profile-trigger" type="button">
                        <span class="avatar">AI</span>
                        <span class="profile-meta">Admin</span>
                        <i class="fa-solid fa-chevron-down"></i>
                    </button>
                    <div class="profile-dropdown">
                        <a href="#students">Manage Students</a>
                        <a href="/attendance">Live Scanner</a>
                        <a href="/system-events">Event Monitor</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="app-shell" id="dashboard">
        <section class="hero-section reveal">
            <div class="hero-copy">
                <div class="status-chip"><span class="live-dot"></span> AI security network online</div>
                <h1>Face Recognition Attendance System</h1>
                <p>Advanced AI-powered attendance tracking using facial recognition technology.</p>
                <div class="hero-actions">
                    <a href="/attendance" class="btn btn-primary"><i class="fa-solid fa-camera"></i> Start Scanning</a>
                    <a href="#records" class="btn btn-secondary"><i class="fa-solid fa-table-list"></i> View Attendance</a>
                </div>
                <div class="hero-metrics">
                    <span><strong><%= safeStudents.length %></strong> identities</span>
                    <span><strong><%= safeRecentAttendance.length %></strong> scans today</span>
                    <span><strong>99.7%</strong> AI match confidence</span>
                </div>
            </div>

            <div class="scanner-visual" aria-label="Animated face scanning illustration">
                <div class="scanner-grid"></div>
                <div class="face-frame">
                    <span class="corner top-left"></span>
                    <span class="corner top-right"></span>
                    <span class="corner bottom-left"></span>
                    <span class="corner bottom-right"></span>
                    <div class="face-orbit">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <div class="scan-line"></div>
                    <div class="biometric-lines">
                        <span style="--w: 78%"></span>
                        <span style="--w: 52%"></span>
                        <span style="--w: 86%"></span>
                    </div>
                </div>
                <div class="scanner-card card-left">
                    <span>Neural Match</span>
                    <strong>99.7%</strong>
                </div>
                <div class="scanner-card card-right">
                    <span>Status</span>
                    <strong>Verified</strong>
                </div>
            </div>
        </section>

        <section class="widget-grid reveal">
            <div class="metric-card">
                <span class="metric-icon"><i class="fa-solid fa-chart-pie"></i></span>
                <p>Attendance Percentage</p>
                <strong class="counter" data-count="<%= attendancePct %>"><%= attendancePct %>%</strong>
            </div>
            <div class="metric-card">
                <span class="metric-icon"><i class="fa-solid fa-users"></i></span>
                <p>Total Students</p>
                <strong class="counter" data-count="<%= safeStudents.length %>"><%= safeStudents.length %></strong>
            </div>
            <div class="metric-card">
                <span class="metric-icon"><i class="fa-solid fa-video"></i></span>
                <p>Active Cameras</p>
                <strong>01</strong>
            </div>
            <div class="metric-card">
                <span class="metric-icon"><i class="fa-solid fa-brain"></i></span>
                <p>AI Accuracy</p>
                <strong>99.7%</strong>
            </div>
            <div class="metric-card">
                <span class="metric-icon"><i class="fa-solid fa-calendar-check"></i></span>
                <p>Today's Attendance</p>
                <strong><%= safeRecentAttendance.length %></strong>
            </div>
            <div class="metric-card">
                <span class="metric-icon"><i class="fa-solid fa-satellite-dish"></i></span>
                <p>Live Monitoring</p>
                <strong><span class="live-dot"></span> Active</strong>
            </div>
        </section>

        <section class="dashboard-grid reveal" id="students">
            <div class="panel enrollment-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Identity Enrollment</p>
                        <h2>Register Student</h2>
                    </div>
                    <span class="panel-badge">Cloud sync</span>
                </div>
                <form id="student-form" class="stack-form">
                    <div class="form-grid">
                        <label><span>Name</span><input type="text" name="name" placeholder="Raj Patel" required></label>
                        <label><span>Face Label</span><input type="text" name="faceLabel" placeholder="raj_patel" required></label>
                        <label><span>Joining Date</span><input type="date" name="joiningDate" required></label>
                        <label><span>Student ID</span><input type="text" name="rollNumber" placeholder="STU-101"></label>
                        <label><span>Department</span><input type="text" name="department" placeholder="Computer Science"></label>
                        <label><span>Email</span><input type="email" name="email" placeholder="raj@example.com"></label>
                    </div>
                    <div class="camera-shell enrollment-shell">
                        <div class="camera-frame scanner-frame">
                            <video id="enrollment-camera-feed" autoplay playsinline muted></video>
                            <canvas id="enrollment-camera-canvas" hidden></canvas>
                            <span class="camera-reticle"></span>
                        </div>
                        <div class="camera-controls">
                            <button type="button" id="start-enrollment-camera" class="btn btn-secondary"><i class="fa-solid fa-video"></i> Start Camera</button>
                            <button type="button" id="capture-enrollment" class="btn btn-primary"><i class="fa-solid fa-crosshairs"></i> Capture Samples</button>
                            <button type="button" id="stop-enrollment-camera" class="btn btn-secondary"><i class="fa-solid fa-video-slash"></i> Stop Camera</button>
                        </div>
                        <p id="enrollment-camera-status" class="helper-text">Camera is off. Start camera to capture face samples.</p>
                        <p id="enrollment-sample-status" class="form-status">Minimum: 6 samples | Recommended: 12 samples</p>
                    </div>
                    <div id="enrollment-preview" class="sample-grid"></div>
                    <button type="submit" class="btn btn-primary wide"><i class="fa-solid fa-cloud-arrow-up"></i> Save Identity & Train AI</button>
                    <p id="student-form-status" class="form-status"></p>
                </form>
            </div>

            <div class="panel workflow-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">AI Pipeline</p>
                        <h2>Verification Flow</h2>
                    </div>
                </div>
                <div class="timeline-list">
                    <div class="timeline-item"><span>01</span><div><strong>Capture biometrics</strong><p>Multi-frame face samples with quality hints.</p></div></div>
                    <div class="timeline-item"><span>02</span><div><strong>Cloud archive</strong><p>Samples sync to Cloudinary and metadata goes to MongoDB.</p></div></div>
                    <div class="timeline-item"><span>03</span><div><strong>Embedding train</strong><p>Python model updates recognition vectors.</p></div></div>
                    <div class="timeline-item"><span>04</span><div><strong>Live match</strong><p>Attendance scanner verifies and marks daily presence.</p></div></div>
                </div>
                <div class="preview-card">
                    <div class="circular-progress" style="--value: 86"><span>86%</span></div>
                    <div><strong>Readiness Score</strong><p>Enrollment, model, camera and database services are monitored together.</p></div>
                </div>
            </div>
        </section>

        <section class="analytics-grid reveal" id="analytics">
            <div class="panel chart-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Weekly Intelligence</p>
                        <h2>Attendance Graph</h2>
                    </div>
                </div>
                <div class="bar-chart">
                    <span style="--h: 62%"><b>Mon</b></span>
                    <span style="--h: 78%"><b>Tue</b></span>
                    <span style="--h: 54%"><b>Wed</b></span>
                    <span style="--h: 88%"><b>Thu</b></span>
                    <span style="--h: 72%"><b>Fri</b></span>
                    <span style="--h: 40%"><b>Sat</b></span>
                    <span style="--h: 31%"><b>Sun</b></span>
                </div>
            </div>
            <div class="panel heatmap-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Heatmap</p>
                        <h2>Live Presence Density</h2>
                    </div>
                </div>
                <div class="heatmap">
                    <% for (let i = 0; i < 35; i += 1) { %>
                        <span style="--alpha: <%= ((i % 7) + 2) / 10 %>"></span>
                    <% } %>
                </div>
            </div>
        </section>

        <section class="dashboard-grid reveal" id="records">
            <div class="panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Students</p>
                        <h2>Registered Identities</h2>
                    </div>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Name</th><th>Label</th><th>Joining</th><th>Department</th></tr></thead>
                        <tbody id="students-table-body">
                            <% if (safeStudents.length === 0) { %><tr><td colspan="4">No students added yet.</td></tr><% } %>
                            <% safeStudents.forEach((student) => { %>
                                <tr>
                                    <td><%= student.name %></td>
                                    <td><code><%= student.faceLabel %></code></td>
                                    <td><%= student.joiningDate ? new Date(student.joiningDate).toLocaleDateString() : '-' %></td>
                                    <td><%= student.department || '-' %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Real Time</p>
                        <h2>Recent Attendance</h2>
                    </div>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Name</th><th>Time</th><th>Confidence</th></tr></thead>
                        <tbody id="attendance-table-body">
                            <% if (safeRecentAttendance.length === 0) { %><tr><td colspan="3">No attendance marked yet.</td></tr><% } %>
                            <% safeRecentAttendance.forEach((record) => { %>
                                <tr>
                                    <td><%= record.student ? record.student.name : record.faceLabel %></td>
                                    <td><%= new Date(record.markedAt).toLocaleString() %></td>
                                    <td><%= Number(record.confidence || 0).toFixed(3) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <div class="toast-stack" id="toast-stack"></div>
    <script src="/script.js"></script>
</body>
</html>
