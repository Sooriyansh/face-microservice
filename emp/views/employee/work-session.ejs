<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily Workday | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="<%= currentUser ? currentUser.role : 'employee' %>">
  <% const safeEmployee = typeof employee !== 'undefined' && employee ? employee : null; %>
  <% const safeWorkSession = typeof workSession !== 'undefined' ? workSession : null; %>
  <div class="enterprise-layout employee-layout">
    <%- include('partials/sidebar', { activePage: 'work-session' }) %>
    <main class="workspace">
      <%- include('partials/topbar', { syncLabel: 'Work session' }) %>
      <section class="page-hero reveal"><div><span class="status-chip"><span class="live-dot"></span>Workday actions</span><h1>Daily Workday</h1><p>Start work, add your plan, and check out when your day is finished.</p></div></section>
      <section class="panel work-session-console reveal" id="daily-work-session" data-employee-id="<%= safeEmployee ? safeEmployee._id : '' %>">
        <div class="panel-header split"><div><p class="eyebrow">Workday actions</p><h2>Daily Workday</h2><p class="helper-text">Start work, add your plan, and check out when you finish.</p></div><span class="panel-badge" id="session-sync-badge"><span class="live-dot"></span> Ready</span></div>
        <div class="workday-action-grid">
          <button type="button" class="workday-action join" id="join-work-button" <%= safeWorkSession && safeWorkSession.status !== 'checked_out' ? 'disabled' : '' %>><i class="fa-solid fa-play"></i><span>JOIN WORK</span><small>Start today's workday</small></button>
          <button type="button" class="workday-action checkout" id="checkout-work-button" <%= !safeWorkSession || safeWorkSession.status === 'checked_out' ? 'disabled' : '' %> data-session-id="<%= safeWorkSession ? safeWorkSession._id : '' %>"><i class="fa-solid fa-flag-checkered"></i><span>CHECK OUT</span><small>Submit your end-of-day report</small></button>
        </div>
        <div class="session-grid">
          <div class="session-status-card"><span class="session-state <%= safeWorkSession ? safeWorkSession.status : 'offline' %>" id="session-state-dot"></span><p>Current Work Status</p><strong id="session-status-text"><%= safeWorkSession ? safeWorkSession.status.replace('_', ' ').toUpperCase() : 'ATTENDANCE NEEDED' %></strong><small id="session-status-detail"><%= safeWorkSession ? 'Work tracking is active today.' : 'Mark attendance to start your workday.' %></small></div>
          <div class="session-status-card"><i class="fa-solid fa-stopwatch"></i><p>Work Timer</p><strong id="session-timer" data-started-at="<%= safeWorkSession && safeWorkSession.startedAt ? new Date(safeWorkSession.startedAt).toISOString() : '' %>" data-checkout-at="<%= safeWorkSession && safeWorkSession.checkoutAt ? new Date(safeWorkSession.checkoutAt).toISOString() : '' %>">00:00:00</strong><small>Total work time tracked today</small></div>
          <div class="session-status-card"><i class="fa-solid fa-wave-square"></i><p>Work Activity</p><strong id="session-event-count"><%= safeWorkSession && safeWorkSession.events ? safeWorkSession.events.length : 0 %></strong><small>Work activity saved today</small></div>
          <div class="session-status-card"><i class="fa-solid fa-gauge-high"></i><p>Work Progress</p><strong id="session-productivity"><%= safeWorkSession ? safeWorkSession.productivityScore : 0 %>%</strong><small>Based on active time, idle time, and checkout details</small></div>
        </div>
        <div class="daily-plan-card"><span><i class="fa-solid fa-list-check"></i> Today's Work Plan</span><p id="daily-plan-preview"><%= safeWorkSession && safeWorkSession.dailyPlan ? safeWorkSession.dailyPlan : "No work plan submitted yet. Click JOIN WORK to add today's plan." %></p></div>
        <div class="session-monitor-layout">
          <div><div class="mini-section-header"><h3>Work Activity Panel</h3><span class="sync-pill"><span class="live-dot"></span>Live activity</span></div><div class="timeline-stream animated-timeline" id="employee-session-events">
            <% if (!safeWorkSession || !safeWorkSession.events || safeWorkSession.events.length === 0) { %><div><span class="event-dot"></span><strong>No work activity yet</strong><p>Click JOIN WORK to start today's workday.</p></div><% } %>
            <% if (safeWorkSession && safeWorkSession.events) { safeWorkSession.events.slice(-10).reverse().forEach((event) => { %><div><span class="event-dot"></span><strong><%= event.type %></strong><p><%= new Date(event.occurredAt).toLocaleString() %> - <%= event.message || event.deviceInfo || 'Live activity event' %></p></div><% }) } %>
          </div></div>
          <div class="monitor-health-panel"><div><span class="live-dot"></span><strong>Workday</strong><p id="ws-health"><%= safeWorkSession && safeWorkSession.status !== 'checked_out' ? 'Active' : 'Not started' %></p></div><div><span class="live-dot"></span><strong>Today's Plan</strong><p><%= safeWorkSession && safeWorkSession.dailyPlan ? 'Submitted' : 'Waiting for your plan' %></p></div><div><span class="live-dot"></span><strong>Checkout Report</strong><p id="collector-health"><%= safeWorkSession && safeWorkSession.status === 'checked_out' ? 'Submitted' : 'Pending' %></p></div><button type="button" class="btn btn-primary wide" id="complete-daily-task" <%= !safeWorkSession || safeWorkSession.status === 'checked_out' ? 'disabled' : '' %> data-session-id="<%= safeWorkSession ? safeWorkSession._id : '' %>"><i class="fa-solid fa-circle-check"></i> Check Out</button><p class="form-status" id="checkout-result"><%= safeWorkSession && safeWorkSession.status === 'checked_out' ? "Today's workday was completed successfully." : '' %></p></div>
        </div>
      </section>
    </main>
  </div>
  <%- include('partials/work-session-modals') %>
  <%- include('partials/scripts') %>
</body>
</html>
