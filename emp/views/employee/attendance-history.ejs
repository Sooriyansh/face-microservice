<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Attendance | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="<%= currentUser ? currentUser.role : 'employee' %>">
  <% const safeRecords = typeof records !== 'undefined' ? records : []; %>
  <div class="enterprise-layout employee-layout">
    <%- include('partials/sidebar', { activePage: 'my-attendance' }) %>
    <main class="workspace">
      <%- include('partials/topbar', { syncLabel: 'Attendance history' }) %>
      <section class="page-hero reveal"><div><span class="status-chip"><span class="live-dot"></span>Private attendance records</span><h1>My Attendance</h1><p>Review your personal attendance history and scan confidence results.</p></div></section>
      <section class="metric-grid compact reveal">
        <div class="metric-card"><span class="metric-icon success"><i class="fa-solid fa-calendar-check"></i></span><p>Attendance Records</p><strong><%= safeRecords.length %></strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-fingerprint"></i></span><p>Latest Confidence</p><strong><%= safeRecords[0] ? Number(safeRecords[0].confidence || 0).toFixed(3) : '-' %></strong></div>
      </section>
      <section class="panel reveal" id="personal-attendance">
        <div class="panel-header"><div><p class="eyebrow">Attendance history</p><h2>My Attendance History</h2></div></div>
        <div class="table-wrap"><table><thead><tr><th>Date</th><th>Time</th><th>Confidence</th><th>Status</th></tr></thead><tbody id="attendance-page-body">
          <% if (safeRecords.length === 0) { %><tr><td colspan="4">No personal attendance records found.</td></tr><% } %>
          <% safeRecords.forEach((record) => { %><tr><td><%= record.dateKey %></td><td><%= new Date(record.markedAt).toLocaleTimeString() %></td><td><%= Number(record.confidence || 0).toFixed(3) %></td><td><span class="security-badge">Present</span></td></tr><% }) %>
        </tbody></table></div>
      </section>
    </main>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
