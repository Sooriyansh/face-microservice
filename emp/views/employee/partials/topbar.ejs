<% const topbarEmployee = typeof employee !== 'undefined' && employee ? employee : null; %>
<% const topbarUser = typeof currentUser !== 'undefined' ? currentUser : null; %>
<header class="topbar">
  <button class="mobile-menu-toggle" type="button" aria-label="Open navigation"><i class="fa-solid fa-bars"></i></button>
  <label class="search-box"><i class="fa-solid fa-lock"></i><input type="search" value="<%= topbarEmployee ? topbarEmployee.name : 'Employee demo profile' %>" readonly></label>
  <div class="topbar-actions">
    <span class="sync-pill"><span class="live-dot"></span><%= typeof syncLabel !== 'undefined' ? syncLabel : 'Personal live sync' %></span>
    <span class="clock" id="real-time-clock">--:--</span>
    <button class="icon-button notification-trigger" id="notification-button" type="button" aria-label="Notifications"><i class="fa-solid fa-bell"></i><span class="notification-count" id="notification-count" hidden>0</span></button>
    <span class="avatar"><%= topbarEmployee ? topbarEmployee.name.slice(0,2).toUpperCase() : (topbarUser ? topbarUser.name.slice(0,2).toUpperCase() : 'EM') %></span>
  </div>
</header>
