<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="admin">
  <% const schedule = typeof workSchedule !== 'undefined' && workSchedule ? workSchedule : {}; %>
  <div class="enterprise-layout">
    <%- include('partials/admin-sidebar', { activePage: 'settings' }) %>
    <main class="workspace">
      <%- include('partials/admin-topbar', { searchId: 'settings-search', searchPlaceholder: 'Search settings', syncLabel: 'Admin settings' }) %>
      <section class="page-hero reveal"><div><span class="status-chip"><span class="live-dot"></span>Settings</span><h1>Settings</h1><p>Manage account, message, employee access, and activity settings from one place.</p></div></section>
      <section class="metric-grid compact reveal">
        <a class="metric-card" href="/admin/notifications"><span class="metric-icon warning"><i class="fa-solid fa-bell"></i></span><p>Message Settings</p><strong>Open</strong></a>
        <a class="metric-card" href="/admin/system-events"><span class="metric-icon violet"><i class="fa-solid fa-timeline"></i></span><p>Activity Tracking</p><strong>Open</strong></a>
        <a class="metric-card" href="/admin/employees"><span class="metric-icon info"><i class="fa-solid fa-users-gear"></i></span><p>Employee Access</p><strong>Open</strong></a>
      </section>
      <section class="panel reveal">
        <div class="panel-header split">
          <div><p class="eyebrow">Work Schedule</p><h2>Office Timing Settings</h2><p class="helper-text">These timings apply to every employee dashboard and are used for late entry and overtime calculations.</p></div>
          <span class="panel-badge">Admin only</span>
        </div>
        <form id="work-schedule-form" class="control-panel">
          <div class="filter-controls"><label>Office Join Time</label><input type="time" name="officeJoinTime" value="<%= schedule.officeJoinTime || '08:00' %>" required></div>
          <div class="filter-controls"><label>Check Out Time</label><input type="time" name="checkOutTime" value="<%= schedule.checkOutTime || '17:00' %>" required></div>
          <div class="filter-controls"><label>Working Hours</label><input type="number" name="workingHours" min="1" max="24" step="0.25" value="<%= schedule.workingHours || 8 %>" required></div>
          <div class="filter-controls"><label>Break Time (Minutes)</label><input type="number" name="breakMinutes" min="0" step="1" value="<%= schedule.breakMinutes || 0 %>"></div>
          <div class="filter-controls"><label>Grace Period (Minutes)</label><input type="number" name="gracePeriodMinutes" min="0" step="1" value="<%= schedule.gracePeriodMinutes || 0 %>"></div>
          <div class="filter-controls"><label>Overtime Start Time</label><input type="time" name="overtimeStartTime" value="<%= schedule.overtimeStartTime || schedule.checkOutTime || '17:00' %>" required></div>
          <div class="filter-controls"><label>&nbsp;</label><button class="btn btn-primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Schedule</button></div>
        </form>
        <p id="work-schedule-status" class="helper-text"><%= typeof scheduleError !== 'undefined' ? scheduleError : 'Schedule is loaded.' %></p>
      </section>
    </main>
  </div>
  <div class="toast-stack" id="toast-stack"></div>
  <%- include('../../../views/shared/notification-center') %>
  <script>window.firebaseWebConfig = <%- JSON.stringify(firebaseConfig || {}) %>;</script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-messaging-compat.js"></script>
  <script src="/js/shared/script.js"></script>
</body>
</html>
