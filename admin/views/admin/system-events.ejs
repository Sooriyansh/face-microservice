<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>System Events | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="admin">
  <% const safeSystemEvents = typeof systemEvents !== 'undefined' ? systemEvents : []; %>
  <% const safeStudents = typeof students !== 'undefined' ? students : []; %>
  <% const safeRange = typeof systemEventRange !== 'undefined' ? systemEventRange : null; %>
  <div class="enterprise-layout">
    <aside class="side-nav">
      <a href="/admin/dashboard" class="brand-block"><span class="brand-mark"><i class="fa-solid fa-shield-halved"></i></span><span><strong>FaceAI</strong><small>Security Timeline</small></span></a>
      <nav class="side-menu">
        <a href="/admin/dashboard"><i class="fa-solid fa-grid-2"></i>Dashboard</a>
        <a href="/admin/attendance"><i class="fa-solid fa-calendar-check"></i>Attendance</a>
        <a href="/admin/employees"><i class="fa-solid fa-users-gear"></i>Employees</a>
        <a class="active" href="/admin/system-events"><i class="fa-solid fa-timeline"></i>System Events</a>
      </nav>
      <div class="rbac-card"><span class="security-badge">Admin role</span><p>Filter any registered employee and inspect complete laptop, login, lock, attendance, and live activity history.</p></div>
      <form action="/logout" method="POST" class="logout-form"><button type="submit">Logout</button></form>
    </aside>

    <main class="workspace">
      <header class="topbar">
        <button class="mobile-menu-toggle" type="button" aria-label="Open navigation"><i class="fa-solid fa-bars"></i></button>
        <label class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input id="event-search" type="search" placeholder="Search employee or event"></label>
        <div class="topbar-actions">
          <span class="sync-pill"><span class="live-dot"></span>Real-time enabled</span>
          <span class="clock" id="real-time-clock">--:--</span>
          <button class="icon-button theme-toggle" type="button" aria-label="Toggle theme"><i class="fa-solid fa-moon"></i></button>
          <span class="security-badge"><%= currentUser ? currentUser.role : 'admin' %></span>
        </div>
      </header>

      <section class="page-hero reveal">
        <div>
          <span class="status-chip"><span class="live-dot"></span> Real-time security timeline dashboard</span>
          <h1>System Events</h1>
          <p>Track employee device activity and work sessions in real-time.</p>
        </div>
        <div class="hero-actions">
          <button id="refresh-system-events" class="btn btn-primary"><i class="fa-solid fa-rotate-right"></i> Refresh Events</button>
          <label class="toggle-pill"><input type="checkbox" id="realtime-system-events" checked> Real-time</label>
          <button class="btn btn-secondary" id="export-system-events" type="button"><i class="fa-solid fa-file-export"></i> Export Logs</button>
        </div>
      </section>

      <section class="control-panel reveal">
        <div class="filter-controls"><label>Date & Time Filter</label><input type="datetime-local" id="system-events-from"><input type="datetime-local" id="system-events-to"></div>
        <div class="filter-controls all-users-control">
          <label for="user-filter">All Employees</label>
          <select id="user-filter"><option value="">All Employees</option></select>
        </div>
        <div class="filter-controls"><label>Department</label><select id="department-filter"><option value="">All departments</option><% [...new Set(safeStudents.map((s) => s.department).filter(Boolean))].forEach((department) => { %><option><%= department %></option><% }) %></select></div>
        <div class="filter-controls"><label>Status</label><select id="online-filter"><option value="">Online/offline</option><option>Online</option><option>Offline</option></select></div>
      </section>

      <section class="metric-grid compact reveal">
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-clock"></i></span><p>Tracking Window</p><strong id="system-events-range"><% if (safeRange) { %><%= new Date(safeRange.start).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %> - <%= new Date(safeRange.end).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %><% } else { %>08:00 - Now<% } %></strong></div>
        <div class="metric-card"><span class="metric-icon"><i class="fa-solid fa-bolt"></i></span><p>Total Events</p><strong id="system-events-count"><%= safeSystemEvents.length %></strong></div>
        <div class="metric-card"><span class="metric-icon violet"><i class="fa-solid fa-shield-check"></i></span><p>Security Accuracy</p><strong id="system-events-accuracy">100%</strong></div>
        <div class="metric-card"><span class="metric-icon success"><i class="fa-solid fa-satellite-dish"></i></span><p>Live Sync Status</p><strong id="system-events-sync">Waiting</strong></div>
      </section>

      <section class="event-type-grid reveal">
        <div class="event-type-card"><i class="fa-solid fa-power-off"></i><strong>Startup</strong><span>Boot detection</span></div>
        <div class="event-type-card"><i class="fa-solid fa-plug-circle-xmark"></i><strong>Shutdown</strong><span>Power-off log</span></div>
        <div class="event-type-card"><i class="fa-solid fa-moon"></i><strong>Sleep/Wakeup</strong><span>Session continuity</span></div>
        <div class="event-type-card"><i class="fa-solid fa-right-to-bracket"></i><strong>Login/Logout</strong><span>User access</span></div>
        <div class="event-type-card"><i class="fa-solid fa-lock"></i><strong>Lock/Unlock</strong><span>Screen security</span></div>
        <div class="event-type-card"><i class="fa-solid fa-camera"></i><strong>Attendance</strong><span>Face recognition activity</span></div>
      </section>

      <section class="admin-grid reveal">
        <div class="panel">
          <div class="panel-header"><div><p class="eyebrow">User filter section</p><h2>Registered Employees</h2></div></div>
          <div class="employee-filter-list">
            <% if (safeStudents.length === 0) { %><p class="helper-text">No registered employees yet.</p><% } %>
            <% safeStudents.forEach((student, index) => { %>
              <button class="employee-filter-card" type="button" data-user="<%= student.name %>" data-department="<%= student.department || '' %>" data-status="<%= index % 3 === 0 ? 'Offline' : 'Online' %>">
                <span class="avatar"><%= student.name.slice(0,2).toUpperCase() %></span>
                <span><strong><%= student.name %></strong><small><%= student.department || 'General' %> · Last active <%= index + 2 %>m ago</small></span>
                <span class="<%= index % 3 === 0 ? 'status-offline' : 'status-online' %>"><%= index % 3 === 0 ? 'Offline' : 'Online' %></span>
              </button>
            <% }) %>
          </div>
        </div>
        <div class="panel">
          <div class="panel-header"><div><p class="eyebrow">Real-time live feed</p><h2>Activity Feed</h2></div></div>
          <div class="activity-feed realtime-feed">
            <div class="severity-success"><span class="live-dot"></span><strong>Rahul laptop started at 08:12 AM</strong><p>Startup · Laptop activity</p></div>
            <div><span class="live-dot"></span><strong>Ankit entered sleep mode</strong><p>Sleep/Wakeup · Session continuity</p></div>
            <div class="severity-success"><span class="live-dot"></span><strong>Priya marked attendance successfully</strong><p>Attendance · Face recognition</p></div>
            <div><span class="live-dot"></span><strong>Rohit unlocked screen</strong><p>Lock/Unlock · Screen security</p></div>
            <div class="severity-danger"><span class="live-dot danger-dot"></span><strong>Aman logged out</strong><p>Logout · User access</p></div>
          </div>
        </div>
      </section>

      <section class="panel reveal">
        <div class="panel-header split">
          <div>
            <p class="eyebrow">Timeline</p>
            <h2>Complete Activity Timeline</h2>
            <p id="system-events-status" class="helper-text">Select an employee to show only that employee's attendance history, system events, laptop activity, login/logout logs, and lock/unlock history.</p>
          </div>
          <span class="panel-badge">Live events stream</span>
        </div>
        <div class="timeline-stream" id="system-events-body">
          <% if (safeSystemEvents.length === 0) { %><div><span class="event-dot"></span><strong>No system event captured yet</strong><p>Waiting for Windows activity monitor payloads.</p></div><% } %>
          <% safeSystemEvents.forEach((event) => { %>
            <div class="event-row" data-user="<%= event.user || 'Unknown' %>">
              <span class="event-dot"></span>
              <strong><%= event.user || 'Unknown' %> · <%= event.event %></strong>
              <p><%= new Date(event.occurredAt).toLocaleString() %> · <%= event.meaning || event.provider || event.sourceLog || '-' %> · Event ID <%= event.eventId %></p>
            </div>
          <% }) %>
        </div>
      </section>
    </main>
  </div>
  <div class="toast-stack" id="toast-stack"></div>
  <script src="/js/shared/script.js"></script>
</body>
</html>

