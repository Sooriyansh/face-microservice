<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily Work Reports | FaceAI Attend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/shared/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body data-role="admin">
  <% const safeReports = typeof reports !== 'undefined' ? reports : []; %>
  <% const safeStudents = typeof students !== 'undefined' ? students : []; %>
  <% const safeFilters = typeof filters !== 'undefined' ? filters : {}; %>
  <% const departments = Array.from(new Set(safeStudents.map((student) => student.department).filter(Boolean))); %>
  <div class="enterprise-layout">
    <aside class="side-nav">
      <a href="/admin/dashboard" class="brand-block"><span class="brand-mark"><i class="fa-solid fa-shield-halved"></i></span><span><strong>FaceAI</strong><small>Reports Console</small></span></a>
      <nav class="side-menu">
        <a href="/admin/dashboard"><i class="fa-solid fa-grid-2"></i>Overview</a>
        <a href="/admin/leave"><i class="fa-solid fa-calendar-minus"></i>Leave Requests</a>
        <a class="active" href="/admin/reports"><i class="fa-solid fa-clipboard-list"></i>Daily Work Reports</a>
        <a href="/admin/overtime"><i class="fa-solid fa-business-time"></i>Overtime</a>
      </nav>
      <div class="rbac-card"><span class="security-badge">Admin access</span><p>Daily plans and checkout reports appear here after employees finish work.</p><form action="/logout" method="POST" class="logout-form"><button type="submit">Logout</button></form></div>
    </aside>
    <main class="workspace">
      <header class="topbar">
        <button class="mobile-menu-toggle" type="button" aria-label="Open navigation"><i class="fa-solid fa-bars"></i></button>
        <label class="search-box"><i class="fa-solid fa-magnifying-glass"></i><input type="search" id="daily-report-search" placeholder="Search reports"></label>
        <div class="topbar-actions">
          <a class="btn btn-secondary" href="/api/hrms/admin/export/daily-reports/csv"><i class="fa-solid fa-file-csv"></i>CSV</a>
          <a class="btn btn-secondary" href="/api/hrms/admin/export/daily-reports/excel"><i class="fa-solid fa-file-excel"></i>Excel</a>
          <a class="btn btn-secondary" href="/api/hrms/admin/export/daily-reports/pdf"><i class="fa-solid fa-file-pdf"></i>PDF</a>
        </div>
      </header>
      <section class="page-hero reveal"><div><span class="status-chip"><span class="live-dot"></span>Employee checkout reports</span><h1>Daily Work Reports</h1><p>Review join time, checkout time, daily plans, work summaries, pending work, and task status.</p></div></section>
      <section class="panel reveal">
        <form class="filter-controls report-filter-bar" method="GET" action="/admin/reports">
          <label><span>Date</span><input type="date" name="date" value="<%= safeFilters.date || '' %>"></label>
          <label><span>Employee</span><select name="employee"><option value="">All employees</option><% safeStudents.forEach((student) => { %><option value="<%= student._id %>" <%= String(safeFilters.employee) === String(student._id) ? 'selected' : '' %>><%= student.name %></option><% }) %></select></label>
          <label><span>Department</span><select name="department"><option value="">All departments</option><% departments.forEach((department) => { %><option value="<%= department %>" <%= safeFilters.department === department ? 'selected' : '' %>><%= department %></option><% }) %></select></label>
          <label><span>Status</span><select name="status"><option value="">All statuses</option><% ['Completed', 'Partially Completed', 'Pending'].forEach((status) => { %><option value="<%= status %>" <%= safeFilters.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select></label>
          <button class="btn btn-primary" type="submit"><i class="fa-solid fa-filter"></i>Apply Filters</button>
        </form>
      </section>
      <section class="panel reveal">
        <div class="table-wrap"><table><thead><tr><th>Employee Name</th><th>Date</th><th>Start Time</th><th>End Time</th><th>Work Plan</th><th>Completed Work</th><th>Pending Work</th><th>Work Status</th></tr></thead><tbody id="daily-reports-body">
          <% if (!safeReports.length) { %><tr><td colspan="8">No daily work reports match the selected filters.</td></tr><% } %>
          <% safeReports.forEach((report) => { %>
            <tr data-status="<%= report.taskStatus || 'Pending' %>">
              <td><span class="person-cell"><span class="avatar"><%= (report.employee?.name || 'EM').slice(0,2).toUpperCase() %></span><strong><%= report.employee?.name || 'Employee' %></strong></span></td>
              <td><%= report.reportDate %></td>
              <td><%= report.joinTime ? new Date(report.joinTime).toLocaleTimeString() : '-' %></td>
              <td><%= report.checkoutTime ? new Date(report.checkoutTime).toLocaleTimeString() : '-' %></td>
              <td><%= report.dailyPlan || '-' %></td>
              <td><%= report.workSummary %></td>
              <td><%= report.pendingTasks %></td>
              <td><span class="status-badge status-<%= String(report.taskStatus || 'Pending').toLowerCase().replaceAll(' ', '-') %>"><%= report.taskStatus || 'Pending' %></span></td>
            </tr>
          <% }) %>
        </tbody></table></div>
      </section>
    </main>
  </div>
  <script src="/js/shared/script.js"></script>
</body>
</html>

